# GMaestro environment variables.
#
# Real values live in ~/.gmaestro/.env (created by `pnpm gmaestro setup`).
# This file documents the required and optional variables.

# ----- REQUIRED -----

# Anthropic API key (sk-ant-...). Get from https://console.anthropic.com/
# Tier 2+ ($40 cumulative spend) recommended for parallel persona fanout.
ANTHROPIC_API_KEY=

# Composio API key. Get from https://agents.composio.dev (agent-native signup)
# or https://composio.dev (standard signup).
#
# IMPORTANT: lib/shared/env.ts will silently fall back to
# ~/.composio/anonymous_user_data.json if this is unset — convenient for local
# dev, but be aware that any MCP configs / OAuth connections you create are
# tied to whichever key is in active use. If you set this here AFTER doing
# OAuth flows, restart the dev server AND expect to re-auth (the new key
# may belong to a different Composio project).
COMPOSIO_API_KEY=

# ----- OPTIONAL (have sane defaults) -----

# Stable user ID for Composio sessions and Drizzle FKs.
# Single-user local app — leave as "default" unless you know what you're doing.
GMAESTRO_USER_ID=default

# Base URL the local dashboard answers on. Used for OAuth callback construction.
# Change only if you tunnel via ngrok/cloudflared.
GMAESTRO_BASE_URL=http://localhost:3000

# Anthropic tier override. "auto" detects via API; "tier1" forces sequential
# dispatch (concurrency = 1); "tier2plus" allows parallel fanout (concurrency = 10).
GMAESTRO_TIER=auto
